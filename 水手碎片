local farmRunning = false
local farmCoroutine = nil
local selectedMap = nil

local function autoFarmLoop()
    local plr = game:GetService("Players").LocalPlayer
    local index = 1
    local lastSwitch = tick()
    local stayTime = 1

    while farmRunning do
        task.wait(0.001)
        local char = plr.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not root or not humanoid then continue end

        local map = farmMaps[selectedMap]
        if not map then
            farmRunning = false
            break
        end

        local npcContainer = workspace:FindFirstChild(map.folder)
        if not npcContainer then
            task.wait(0.5)
            continue
        end

        local npcs = {}
        for _, v in pairs(npcContainer:GetChildren()) do
            if map.match(v) then
                table.insert(npcs, v)
            end
        end

        if #npcs > 0 then
            humanoid.PlatformStand = true
            humanoid.AutoRotate = false
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)

            if index > #npcs then index = 1 end
            if tick() - lastSwitch >= stayTime then
                index = index % #npcs + 1
                lastSwitch = tick()
            end

            local npc = npcs[index]
            local npcRoot = npc:FindFirstChild("HumanoidRootPart")
            if npcRoot then
                root.CFrame = CFrame.new(npcRoot.Position + Vector3.new(0, 6, 0), npcRoot.Position)
            end
        else
            humanoid.PlatformStand = false
            index = 1
            if not _G.farmNoMonsterNotified then
                _G.farmNoMonsterNotified = true
                game.StarterGui:SetCore("SendNotification", {
                    Title = "提示",
                    Text = "未找到 " .. map.name .. " 怪物",
                    Duration = 3
                })
                task.wait(3)
                _G.farmNoMonsterNotified = false
            end
            task.wait(0.5)
        end
    end

    local char = plr.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
    farmRunning = false
end

local function startAutoFarm()
    if farmRunning then return end
    if not selectedMap then
        game.StarterGui:SetCore("SendNotification", {
            Title = "提示",
            Text = "请先选择地图",
            Duration = 2
        })
        return
    end
    farmRunning = true
    farmCoroutine = task.spawn(autoFarmLoop)
end

local function stopAutoFarm()
    farmRunning = false
    if farmCoroutine then
        task.cancel(farmCoroutine)
        farmCoroutine = nil
    end
    local plr = game.Players.LocalPlayer
    local char = plr.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
        end
    end
end

-- ============================================================================
-- 无限跳功能
-- ============================================================================
local infiniteJumpRunning = false
local infiniteJumpCoroutine = nil

local function infiniteJumpLoop()
    local plr = game:GetService("Players").LocalPlayer
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvents")
    if remote then remote = remote:FindFirstChild("MultiJumpRemote") end
    if not remote then
        warn("未找到 MultiJumpRemote 事件，无限跳可能无效")
    end

    while infiniteJumpRunning do
        local char = plr.Character
        if not char then 
            char = plr.CharacterAdded:Wait()
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChild("Humanoid")
        if root and humanoid then
            local basePos = root.Position
            for i = 1, 6 do
                local newPos = Vector3.new(basePos.X, basePos.Y + (i * 3), basePos.Z)
                if remote then pcall(function() remote:FireServer(i, newPos) end) end
                task.wait(0.07)
            end
            humanoid:ChangeState(Enum.HumanoidStateType.Landed)
            task.wait(0.15)
        end
        task.wait()
    end
end

local function startInfiniteJump()
    if infiniteJumpRunning then return end
    infiniteJumpRunning = true
    infiniteJumpCoroutine = task.spawn(infiniteJumpLoop)
end

local function stopInfiniteJump()
    infiniteJumpRunning = false
    if infiniteJumpCoroutine then
        task.cancel(infiniteJumpCoroutine)
        infiniteJumpCoroutine = nil
    end
end

-- ============================================================================
-- 自动攻击功能
-- ============================================================================
local autoAttackRunning = false
local autoAttackCoroutine = nil

local function autoAttackLoop()
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("CombatSystem")
    if remote then remote = remote:FindFirstChild("Remotes") end
    if remote then remote = remote:FindFirstChild("RequestHit") end
    if not remote then
        warn("未找到 CombatSystem.Remotes.RequestHit 事件，自动攻击可能无效")
    end

    while autoAttackRunning do
        if remote then pcall(function() remote:FireServer() end) end
        task.wait(0.05)
    end
end

local function startAutoAttack()
    if autoAttackRunning then return end
    autoAttackRunning = true
    autoAttackCoroutine = task.spawn(autoAttackLoop)
end

local function stopAutoAttack()
    autoAttackRunning = false
    if autoAttackCoroutine then
        task.cancel(autoAttackCoroutine)
        autoAttackCoroutine = nil
    end
end

