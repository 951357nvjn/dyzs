UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        if not isWindowOpen or not mainWindow then
            createMainWindow()
            WindUI:Toast("UI Reopened", 2)
        else
            WindUI:Toast("Press Insert to close and reopen", 2)
        end
    end
