-- ========== Basic Box ESP (no UI customization, just enabled/disabled) ==========
local espEnabled = true
local espData = {}
local espBoxThick = 0.8
local espHealthWidth = 2
local espMaxDist = 200

local function getPlayerDistance(player)
    local char = player.Character
    if not char then return math.huge end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return math.huge end
    local myChar = LocalPlayer.Character
    if not myChar then return math.huge end
    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
    if not myHrp then return math.huge end
    return (myHrp.Position - hrp.Position).Magnitude
end

local function getPlayerBox(player)
    local char = player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return nil end
    local headPos, headOn = Camera:WorldToViewportPoint(head.Position)
    local footPos, footOn = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 2.5, 0))
    if not headOn or not footOn then return nil end
    local top = headPos.Y
    local bottom = footPos.Y
    if bottom < top then bottom, top = top, bottom end
    local height = (bottom - top) * 1.3
    local width = (bottom - top) * 0.7
    local centerX = headPos.X
    local left = centerX - width/2
    local offsetY = (height - (bottom - top)) / 2
    return {
        x = left, y = top - offsetY,
        w = width, h = height
    }
end

local function getPlayerColor(player)
    if LocalPlayer.Team and player.Team then
        return LocalPlayer.Team == player.Team and Color3.fromRGB(80,255,80) or Color3.fromRGB(255,80,80)
    end
    return Color3.fromRGB(255,80,80)
end

local function createESP(player)
    if espData[player] then return end
    local box = Drawing.new("Square")
    box.Thickness = espBoxThick
    box.Filled = false
    local name = Drawing.new("Text")
    name.Center = true
    name.Outline = true
    name.OutlineColor = Color3.new(0,0,0)
    name.Size = 10
    local healthBg = Drawing.new("Line")
    healthBg.Thickness = espHealthWidth
    healthBg.Color = Color3.fromRGB(80,80,80)
    local health = Drawing.new("Line")
    health.Thickness = espHealthWidth
    health.Color = Color3.fromRGB(0,255,0)
    espData[player] = {box=box, name=name, healthBg=healthBg, health=health}
end

local function updateESP(player)
    local data = espData[player]
    if not data then return end
    if not espEnabled then
        data.box.Visible = false
        data.name.Visible = false
        data.healthBg.Visible = false
        data.health.Visible = false
        return
    end
    local dist = getPlayerDistance(player)
    if dist > espMaxDist then
        data.box.Visible = false
        data.name.Visible = false
        data.healthBg.Visible = false
        data.health.Visible = false
        return
    end
    local box = getPlayerBox(player)
    if not box then
        data.box.Visible = false
        data.name.Visible = false
        data.healthBg.Visible = false
        data.health.Visible = false
        return
    end
    local color = getPlayerColor(player)
    data.box.Color = color
    data.box.Position = Vector2.new(box.x, box.y)
    data.box.Size = Vector2.new(box.w, box.h)
    data.box.Visible = true

    data.name.Text = player.Name
    data.name.Color = Color3.new(1,1,1)
    data.name.Position = Vector2.new(box.x + box.w/2, box.y - 8)
    data.name.Visible = true

    local barX = box.x + box.w + 2
    local barTop = box.y
    local barBottom = box.y + box.h
    data.healthBg.From = Vector2.new(barX, barTop)
    data.healthBg.To = Vector2.new(barX, barBottom)
    data.healthBg.Visible = true

    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    local percent = hum and math.clamp(hum.Health / hum.MaxHealth, 0, 1) or 1
    local filledTop = barTop + box.h * (1 - percent)
    data.health.From = Vector2.new(barX, filledTop)
    data.health.To = Vector2.new(barX, barBottom)
    data.health.Visible = true
end

local function clearESP()
    for _, data in pairs(espData) do
        data.box:Remove()
        data.name:Remove()
        data.healthBg:Remove()
        data.health:Remove()
    end
    espData = {}
end

local function initESP()
    if not hasDrawing then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then createESP(plr) end
    end
    Players.PlayerAdded:Connect(function(plr)
        if plr ~= LocalPlayer then createESP(plr) end
    end)
    Players.PlayerRemoving:Connect(function(plr)
        if espData[plr] then
            for _, d in pairs(espData[plr]) do d:Remove() end
            espData[plr] = nil
        end
    end)
    RunService.RenderStepped:Connect(function()
        if not hasDrawing then return end
        for plr, _ in pairs(espData) do
            if plr and plr.Parent then
                updateESP(plr)
            else
                if espData[plr] then
                    for _, d in pairs(espData[plr]) do d:Remove() end
                    espData[plr] = nil
                end
            end
        end
    end)
end

