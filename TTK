                local WeaponsRegistry = require(ReplicatedStorage.Registries.Weapons)
                local BulletController = require(ReplicatedStorage.Modules.Client.Controllers.BulletController)

                local RAGE_MODE = true
                local AIM_PART = "Head"
                local RANDOM_PARTS = false
                local BEAM_FADE_START = 0.5
                local HIT_MARKER_FADE_SPEED = 1.25
                local BEAM_FADE_SPEED = 2.0
                local HIT_MARKER_SIZE = 0.5
                local HIT_MARKER_SHAPE = Enum.PartType.Ball

                local currentWeaponName = nil
                local currentFireRate = 0.08
                local attackCount = 0
                local hitCount = 0
                local killCount = 0
                local lastAttackTime = 0
                local currentTarget = "None"
                local currentBodyPart = "None"

                local BEAM_COLORS = {
                    ["Galaxy"] = Color3.fromRGB(25, 59, 255),
                    ["Fish"] = Color3.fromRGB(255, 85, 255),
                    ["Heaven"] = Color3.fromRGB(255, 255, 255),
                    ["DH-Stars"] = Color3.fromRGB(255, 255, 255),
                    ["8-BIT"] = Color3.fromRGB(0, 242, 255),
                    ["Matrix"] = Color3.fromRGB(41, 141, 33)
                }

                local beamPool = {}
                local activeBeams = 0

                local function acquireBeam()
                    if #beamPool > 0 then
                        return table.remove(beamPool)
                    end
                    return nil
                end

                local function recycleBeamEntry(entry)
                    entry.beam.Enabled = false
                    entry.att0.WorldPosition = Vector3.zero
                    entry.att1.WorldPosition = Vector3.zero
                    table.insert(beamPool, entry)
                    activeBeams = activeBeams - 1
                end

                local fadingBeams = {}

                local function startBeamFade(entry)
                    table.insert(fadingBeams, {
                        entry = entry,
                        alpha = 0.1,
                        fadeSpeed = BEAM_FADE_SPEED
                    })
                end

                local activeHitMarkers = {}

                local function createHitMarker(hitPos, color)
                    local part = Instance.new("Part")
                    part.Name = "HitMarker"
                    part.Shape = HIT_MARKER_SHAPE
                    part.Size = Vector3.new(HIT_MARKER_SIZE, HIT_MARKER_SIZE, HIT_MARKER_SIZE)
                    part.Position = hitPos
                    part.Anchored = true
                    part.CanCollide = false
                    part.Color = color
                    part.Material = Enum.Material.Neon
                    part.Transparency = 0
                    part.Parent = workspace

                    table.insert(activeHitMarkers, {
                        part = part,
                        alpha = 0,
                        fadeSpeed = HIT_MARKER_FADE_SPEED
                    })
                end

                local function getCurrentWeapon()
                    local attr = player:GetAttribute("CurrentWeapon")
                    if attr and typeof(attr) == "string" then return attr end
                    local char = player.Character
                    if char then
                        for _, child in ipairs(char:GetChildren()) do
                            if child:IsA("Tool") then return child.Name end
                        end
                    end
                    return nil
                end

                local function isDead(part)
                    local check = part
                    while check and check ~= workspace do
                        if check:GetAttribute("Dead") == true then return true end
                        check = check.Parent
                    end
                    return false
                end

                local raycastParams = RaycastParams.new()
                raycastParams.FilterType = Enum.RaycastFilterType.Exclude

                local function updateRaycastFilter()
                    local filter = {player.Character, workspace.CurrentCamera}
                    local merc = workspace:FindFirstChild("MercPlayers")
                    if merc then table.insert(filter, merc) end
                    local map = workspace:FindFirstChild("ActiveMap") or workspace:FindFirstChild("Map")
                    if map then
                        local touchables = map:FindFirstChild("Touchables")
                        if touchables then table.insert(filter, touchables) end
                        local ignore = map:FindFirstChild("Ignore")
                        if ignore then table.insert(filter, ignore) end
                    end
                    local ignoreFolder = workspace:FindFirstChild("Ignore")
                    if ignoreFolder then table.insert(filter, ignoreFolder) end
                    raycastParams.FilterDescendantsInstances = filter
                end
                updateRaycastFilter()
                
                local playerAddedConn = Players.PlayerAdded:Connect(updateRaycastFilter)
                local playerRemovingConn = Players.PlayerRemoving:Connect(updateRaycastFilter)

                local function hasWallBetween(fromPos, toPos)
                    local direction = toPos - fromPos
                    local distance = direction.Magnitude
                    if distance < 0.1 then return false end
                    local rayResult = workspace:Raycast(fromPos, direction.Unit * (distance - 0.1), raycastParams)
                    return rayResult ~= nil
                end

                local function getClosestTarget()
                    local char = player.Character
                    if not char then return nil end
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if not root then return nil end

                    local myUserId = player.UserId
                    local closestDist = math.huge
                    local result = {}

                    for _, part in ipairs(CollectionService:GetTagged("MercBodyPart")) do
                        if part:IsA("BasePart") and part.Parent and not isDead(part) then
                            local ownerId = part:GetAttribute("OwnerUserId")
                            local bodyPartName = part:GetAttribute("MercBodyPart")
                            local targetChar = part:FindFirstAncestorOfClass("Model")
                            if not ownerId and targetChar then
                                ownerId = targetChar:GetAttribute("OwnerUserId")
                            end
                            if not bodyPartName then
                                bodyPartName = part.Name
                            end
                            if ownerId and ownerId ~= myUserId and bodyPartName then
                                local dist = (root.Position - part.Position).Magnitude
                                if dist < closestDist and not hasWallBetween(root.Position, part.Position) then
                                    closestDist = dist
                                    result = {
                                        userId = ownerId,
                                        hitPos = part.Position,
                                        direction = (part.Position - root.Position).Unit,
                                        bodyPart = bodyPartName,
                                        char = targetChar
                                    }
                                end
                            end
                        end
                    end
                    if result.userId then
                        return result.userId, result.hitPos, result.direction, result.bodyPart, result.char, closestDist
                    end
                    return nil
                end

                local function getRandomBeamColor()
                    local keys = {}
                    for k in pairs(BEAM_COLORS) do table.insert(keys, k) end
                    return BEAM_COLORS[keys[math.random(#keys)]]
                end

                local function createBulletBeam(origin, hitPos)
                    local beamColor = getRandomBeamColor()
                    local poolEntry = acquireBeam()
                    local entry

                    if poolEntry then
                        entry = poolEntry
                        entry.beam.Enabled = true
                        entry.att0.WorldPosition = origin
                        entry.att1.WorldPosition = hitPos
                    else
                        local att0 = Instance.new("Attachment")
                        att0.Parent = workspace.Terrain
                        att0.WorldPosition = origin

                        local att1 = Instance.new("Attachment")
                        att1.Parent = workspace.Terrain
                        att1.WorldPosition = hitPos

                        local beam = Instance.new("Beam")
                        beam.FaceCamera = true
                        beam.Width0 = 0.2
                        beam.Width1 = 0.2
                        beam.Color = ColorSequence.new(beamColor)
                        beam.LightEmission = 1
                        beam.LightInfluence = 0
                        beam.Transparency = NumberSequence.new(0.1)
                        beam.Attachment0 = att0
                        beam.Attachment1 = att1
                        beam.Parent = workspace

                        entry = {
                            beam = beam,
                            att0 = att0,
                            att1 = att1
                        }
                    end

                    activeBeams = activeBeams + 1

                    createHitMarker(hitPos, beamColor)

                    task.delay(BEAM_FADE_START, function()
                        startBeamFade(entry)
                    end)
                end

                local screenGui = Instance.new("ScreenGui")
                screenGui.Name = "StatsDisplay"
                screenGui.ResetOnSpawn = false
                screenGui.Parent = playerGui

                local function createLabel(name, position, size, color, font)
                    local label = Instance.new("TextLabel")
                    label.Name = name
                    label.Size = size
                    label.Position = position
                    label.BackgroundTransparency = 1
                    label.Font = font or Enum.Font.GothamBold
                    label.TextSize = 16
                    label.TextColor3 = color or Color3.fromRGB(255, 255, 0)
                    label.TextStrokeTransparency = 0.5
                    label.TextXAlignment = Enum.TextXAlignment.Left
                    label.Parent = screenGui
                    return label
                end

                local weaponLabel = createLabel("WeaponLabel", UDim2.new(0, 300, 0, 25), UDim2.new(0, 10, 0, 10), Color3.fromRGB(255, 255, 0))
                local statsLabel = createLabel("StatsLabel", UDim2.new(0, 300, 0, 20), UDim2.new(0, 10, 0, 35), Color3.fromRGB(100, 255, 100), Enum.Font.Gotham)
                local targetLabel = createLabel("TargetLabel", UDim2.new(0, 300, 0, 20), UDim2.new(0, 10, 0, 55), Color3.fromRGB(255, 200, 100), Enum.Font.Gotham)
                local rageLabel = createLabel("RageLabel", UDim2.new(0, 300, 0, 20), UDim2.new(0, 10, 0, 75), Color3.fromRGB(255, 0, 0))
                local distLabel = createLabel("DistLabel", UDim2.new(0, 300, 0, 20), UDim2.new(0, 10, 0, 95), Color3.fromRGB(0, 200, 255), Enum.Font.Gotham)

                local connections = {}

                connections[1] = playerAddedConn
                connections[2] = playerRemovingConn
                
                connections[3] = BulletController.HitConfirmed:Connect(function()
                    hitCount = hitCount + 1
                end)

                connections[4] = BulletController.KillConfirmed:Connect(function()
                    killCount = killCount + 1
                end)

                local shotSequence = 0
                local lastDeltaTime = 0.016

                connections[5] = RunService.Heartbeat:Connect(function()
                    if not rageEnabled then return end
                    
                    local now = tick()
                    if lastAttackTime ~= 0 then
                        lastDeltaTime = now - lastAttackTime
                    end

                    for i = #activeHitMarkers, 1, -1 do
                        local entry = activeHitMarkers[i]
                        entry.alpha = entry.alpha + entry.fadeSpeed * lastDeltaTime
                        local alpha = math.min(entry.alpha, 1)
                        entry.part.Transparency = alpha
                        if alpha >= 1 then
                            entry.part:Destroy()
                            table.remove(activeHitMarkers, i)
                        end
                    end

                    for i = #fadingBeams, 1, -1 do
                        local fb = fadingBeams[i]
                        fb.alpha = fb.alpha + fb.fadeSpeed * lastDeltaTime
                        local alpha = math.min(fb.alpha, 1)
                        fb.entry.beam.Transparency = NumberSequence.new(alpha)
                        if alpha >= 1 then
                            recycleBeamEntry(fb.entry)
                            table.remove(fadingBeams, i)
                        end
                    end

                    local weapon = getCurrentWeapon()
                    if not weapon then
                        weaponLabel.Text = "No weapon"
                        return
                    end

                    if weapon ~= currentWeaponName then
                        currentWeaponName = weapon
                        currentFireRate = RAGE_MODE and 0 or (WeaponsRegistry[weapon] and WeaponsRegistry[weapon].FireRate * 2 or 0.16)
                        local rpm = currentFireRate > 0 and math.floor(60 / currentFireRate) or "∞"
                        weaponLabel.Text = string.format("%s | %s RPM | %s", weapon, rpm, RAGE_MODE and "RAGE" or "NORMAL")
                    end

                    if not RAGE_MODE and now - lastAttackTime < currentFireRate then return end

                    local targetUserId, hitPos, direction, bodyPart, targetChar, distance = getClosestTarget()
                    if not targetUserId then
                        targetLabel.Text = "Target: None"
                        distLabel.Text = ""
                        return
                    end

                    if RAGE_MODE then
                        bodyPart = AIM_PART
                    elseif RANDOM_PARTS then
                        local parts = {"Head", "Torso", "LeftArm", "RightArm", "LeftLeg", "RightLeg"}
                        bodyPart = parts[math.random(#parts)]
                    end

                    local char = player.Character
                    if not char then return end
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if not root then return end

                    local origin = root.Position
                    shotSequence = shotSequence + 1
                    attackCount = attackCount + 1
                    lastAttackTime = now

                    WeaponFired:FireServer(weapon, origin, direction, targetUserId, shotSequence)
                    MercHitClaim:FireServer(weapon, targetUserId, bodyPart, origin, direction, hitPos, shotSequence)

                    createBulletBeam(origin, hitPos)

                    currentTarget = tostring(targetUserId)
                    currentBodyPart = bodyPart
                    local hitPercentStr = "0.0"
                    if attackCount > 0 then
                        hitPercentStr = string.format("%.1f", (hitCount / attackCount) * 100)
                    end
                    statsLabel.Text = string.format("Kills:%d | Hits:%d/%d | Acc:%s%%", killCount, hitCount, attackCount, hitPercentStr)
                    targetLabel.Text = string.format("Target: #%s | Part: %s", currentTarget, currentBodyPart)
                    rageLabel.Text = RAGE_MODE and "RAGE MODE ON" or "Normal Mode"
                    distLabel.Text = string.format("Distance: %.0f m", distance)
                end)

                rageConnections = connections
                rageScreenGui = screenGui

                WindUI:Toast("Rage Mode ON", 2)
            else
                if rageConnections then
                    for _, conn in ipairs(rageConnections) do
                        if conn then
                            conn:Disconnect()
                        end
                    end
                    rageConnections = nil
                end
                
                if rageScreenGui then
                    rageScreenGui:Destroy()
                    rageScreenGui = nil
                end

                WindUI:Toast("Rage Mode OFF", 2)
            end
        end
    })

    -- TTK ESP (line + name + highlight)
    local espTTKEnabled = _G.EspTTKEnabled or false
    local espTTKConnections = {}
    local espTTKCache = {}

    local LINE_COLOR = Color3.fromRGB(0, 220, 220)
    local NAME_COLOR = Color3.fromRGB(0, 255, 255)
    local LINE_THICKNESS = 1.2
    local NAME_SIZE = 13
    local MIN_ALPHA = 0.55
    local MAX_ALPHA = 0.25

    local HIGHLIGHT_FILL_COLOR = Color3.fromRGB(0, 220, 220)
    local HIGHLIGHT_OUTLINE_COLOR = Color3.fromRGB(0, 255, 255)
    local HIGHLIGHT_FILL_TRANS = 0.7
    local HIGHLIGHT_OUTLINE_TRANS = 0.3

    local function createTTKESP(player)
        local drawings = {
            Name = Drawing.new("Text"),
            Line = Drawing.new("Line")
        }
        drawings.Name.Visible = false
        drawings.Name.Color = NAME_COLOR
        drawings.Name.Size = NAME_SIZE
        drawings.Name.Outline = true
        drawings.Name.Center = true
        drawings.Name.Transparency = 1

        drawings.Line.Visible = false
        drawings.Line.Color = LINE_COLOR
        drawings.Line.Thickness = LINE_THICKNESS
        drawings.Line.Transparency = 1
        return drawings
    end

    local function applyTTKHighlight(character)
        if not character then return end
        local existing = character:FindFirstChild("ESP_Highlight")
        if existing then existing:Destroy() end
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Highlight"
        highlight.FillColor = HIGHLIGHT_FILL_COLOR
        highlight.OutlineColor = HIGHLIGHT_OUTLINE_COLOR
        highlight.FillTransparency = HIGHLIGHT_FILL_TRANS
        highlight.OutlineTransparency = HIGHLIGHT_OUTLINE_TRANS
        highlight.Adornee = character
        highlight.Parent = character
    end

    local function removeTTKHighlight(character)
        if not character then return end
        local highlight = character:FindFirstChild("ESP_Highlight")
        if highlight then highlight:Destroy() end
    end

    local function startTTKESP()
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local Workspace = game:GetService("Workspace")
        local Camera = Workspace.CurrentCamera
        local LocalPlayer = Players.LocalPlayer

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                espTTKCache[player] = createTTKESP(player)
                if player.Character then
                    applyTTKHighlight(player.Character)
                end
            end
        end

        local playerAddedConn = Players.PlayerAdded:Connect(function(player)
            if player == LocalPlayer then return end
            espTTKCache[player] = createTTKESP(player)
            if player.Character then
                applyTTKHighlight(player.Character)
            end
            local charAddedConn
            charAddedConn = player.CharacterAdded:Connect(function(character)
                applyTTKHighlight(character)
            end)
            local charRemovingConn
            charRemovingConn = player.CharacterRemoving:Connect(function(character)
                removeTTKHighlight(character)
            end)
            table.insert(espTTKConnections, charAddedConn)
            table.insert(espTTKConnections, charRemovingConn)
        end)

        local playerRemovingConn = Players.PlayerRemoving:Connect(function(player)
            local drawings = espTTKCache[player]
            if drawings then
                drawings.Name:Remove()
                drawings.Line:Remove()
                espTTKCache[player] = nil
            end
            if player.Character then
                removeTTKHighlight(player.Character)
            end
        end)

        local renderConn = RunService.RenderStepped:Connect(function()
            if not LocalPlayer.Character or not Camera then return end
            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)

            for player, drawings in pairs(espTTKCache) do
                local character = player.Character
                if character then
                    local rootPart = character:FindFirstChild("HumanoidRootPart")
                    local humanoid = character:FindFirstChild("Humanoid")
                    local head = character:FindFirstChild("Head")

                    if rootPart and humanoid then
                        local hrpPos, hrpOnScreen = Camera:WorldToViewportPoint(rootPart.Position)
                        if hrpOnScreen and hrpPos.Z > 0 then
                            local nameY
                            if head then
                                local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position)
                                nameY = headOnScreen and headPos.Y or (hrpPos.Y - 60 * (1000 / (hrpPos.Z * math.tan(math.rad(Camera.FieldOfView/2))*2)))
                            else
                                nameY = hrpPos.Y - 60 * (1000 / (hrpPos.Z * math.tan(math.rad(Camera.FieldOfView/2))*2))
                            end

                            -- always draw line
                            drawings.Line.Visible = true
                            drawings.Line.From = Vector2.new(hrpPos.X, hrpPos.Y)
                            drawings.Line.To = screenCenter

                            -- always draw name
                            drawings.Name.Visible = true
                            drawings.Name.Position = Vector2.new(hrpPos.X, nameY - 10)
                            drawings.Name.Text = string.format("%s [%dHP]", player.Name, humanoid.Health)

                            local distFactor = math.clamp(1 - hrpPos.Z / 300, 0, 1)
                            local alpha = MIN_ALPHA + (MAX_ALPHA - MIN_ALPHA) * distFactor
                            local transparency = 1 - alpha
                            drawings.Line.Transparency = transparency
                            drawings.Name.Transparency = transparency
                        else
                            drawings.Line.Visible = false
                            drawings.Name.Visible = false
                        end
                    else
                        drawings.Line.Visible = false
                        drawings.Name.Visible = false
                    end
                else
                    drawings.Line.Visible = false
                    drawings.Name.Visible = false
                end
            end
        end)

        table.insert(espTTKConnections, playerAddedConn)
        table.insert(espTTKConnections, playerRemovingConn)
        table.insert(espTTKConnections, renderConn)
    end

    local function stopTTKESP()
        for _, conn in ipairs(espTTKConnections) do
            conn:Disconnect()
        end
        espTTKConnections = {}
        for _, drawings in pairs(espTTKCache) do
            drawings.Name:Remove()
            drawings.Line:Remove()
        end
        espTTKCache = {}
        local Players = game:GetService("Players")
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                removeTTKHighlight(player.Character)
            end
        end
    end

    TTKTab:Toggle({
        Title = "TTK ESP",
        Default = espTTKEnabled,
        Callback = function(state)
            _G.EspTTKEnabled = state
            espTTKEnabled = state
            if state then
                startTTKESP()
            else
                stopTTKESP()
            end
        end
    })

    -- ========== Basic Box ESP (no customization, just toggle) ==========
    TTKTab:Toggle({
        Title = "Box ESP",
        Default = espEnabled,
        Callback = function(state)
            espEnabled = state
            if not state then
                for _, data in pairs(espData) do
                    data.box.Visible = false
                    data.name.Visible = false
                    data.healthBg.Visible = false
                    data.health.Visible = false
                end
            end
        end
    })

    -- Window events
    mainWindow:OnClose(function()
        isWindowOpen = false
        mainWindow = nil
    end)
    mainWindow:OnDestroy(function()
        isWindowOpen = false
        mainWindow = nil
        if rageEnabled and rageConnections then
            for _, conn in ipairs(rageConnections) do
                if conn then conn:Disconnect() end
            end
            rageConnections = nil
            if rageScreenGui then
                rageScreenGui:Destroy()
                rageScreenGui = nil
            end
        end
        if espTTKEnabled then
            stopTTKESP()
        end
        clearESP()
    end)
end

